<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         LAYOUT BASE — shared navbar / page wrapper
    ═══════════════════════════════════════════════════════════════════ -->
    <template id="commission_layout" name="Commission Report Layout">
        <html lang="en">
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title t-out="page_title or 'Commission Report'"/>
                <link rel="stylesheet"
                      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
                <link rel="stylesheet"
                      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap"/>
                <style>
                    /* ─── Reset / Base ───────────────────────────────────── */
                    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
                    body {
                        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
                        background: #F1F5F9;
                        color: #0F172A;
                        min-height: 100vh;
                        -webkit-font-smoothing: antialiased;
                    }

                    /* ─── Navbar ─────────────────────────────────────────── */
                    .cr-nav {
                        background: #ffffff;
                        border-bottom: 1px solid #E2E8F0;
                        height: 64px;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        padding: 0 2rem;
                        position: sticky;
                        top: 0;
                        z-index: 200;
                        box-shadow: 0 1px 12px rgba(15,23,42,.06);
                    }
                    .cr-brand {
                        display: flex;
                        align-items: center;
                        gap: .6rem;
                        font-weight: 700;
                        font-size: 1rem;
                        color: #0F172A;
                        text-decoration: none;
                    }
                    .cr-brand-logo {
                        width: 36px; height: 36px;
                        background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
                        border-radius: 10px;
                        display: flex; align-items: center; justify-content: center;
                        font-size: 1.1rem;
                        flex-shrink: 0;
                    }
                    .cr-nav-actions { display: flex; align-items: center; gap: .6rem; }
                    .cr-nbtn {
                        height: 36px;
                        padding: 0 1rem;
                        border-radius: 8px;
                        font-size: .82rem;
                        font-weight: 500;
                        text-decoration: none;
                        border: 1.5px solid #E2E8F0;
                        color: #475569;
                        background: #fff;
                        cursor: pointer;
                        transition: all .15s ease;
                        display: inline-flex; align-items: center; gap: .35rem;
                        white-space: nowrap;
                    }
                    .cr-nbtn:hover { border-color: #4F46E5; color: #4F46E5; background: #EEF2FF; }

                    /* ─── Page container ─────────────────────────────────── */
                    .cr-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem 5rem; }

                    /* ─── Hero / banner ──────────────────────────────────── */
                    .cr-hero {
                        background: linear-gradient(135deg, #312E81 0%, #4F46E5 40%, #0891B2 100%);
                        border-radius: 20px;
                        padding: 2.25rem 2.5rem;
                        color: #fff;
                        margin-bottom: 1.75rem;
                        position: relative;
                        overflow: hidden;
                    }
                    .cr-hero::before {
                        content: '';
                        position: absolute; top: -50px; right: -30px;
                        width: 240px; height: 240px;
                        background: rgba(255,255,255,.07);
                        border-radius: 50%;
                        pointer-events: none;
                    }
                    .cr-hero::after {
                        content: '';
                        position: absolute; bottom: -70px; right: 100px;
                        width: 180px; height: 180px;
                        background: rgba(255,255,255,.04);
                        border-radius: 50%;
                        pointer-events: none;
                    }
                    .cr-hero-inner { position: relative; z-index: 1; }
                    .cr-hero-pill {
                        display: inline-flex; align-items: center;
                        background: rgba(255,255,255,.18);
                        border: 1px solid rgba(255,255,255,.28);
                        border-radius: 50px;
                        padding: .28rem .9rem;
                        font-size: .75rem; font-weight: 600;
                        letter-spacing: .4px;
                        color: #fff;
                        margin-bottom: .7rem;
                    }
                    .cr-hero-title {
                        font-size: 1.75rem; font-weight: 800;
                        letter-spacing: -.3px; margin-bottom: .35rem;
                    }
                    .cr-hero-sub { font-size: .875rem; opacity: .75; }
                    .cr-hero-btn {
                        display: inline-flex; align-items: center; gap: .4rem;
                        padding: .55rem 1.3rem;
                        background: rgba(255,255,255,.15);
                        border: 1.5px solid rgba(255,255,255,.35);
                        border-radius: 10px;
                        color: #fff; font-size: .85rem; font-weight: 600;
                        cursor: pointer; transition: all .2s; text-decoration: none;
                        backdrop-filter: blur(6px);
                    }
                    .cr-hero-btn:hover { background: rgba(255,255,255,.28); color: #fff; }

                    /* ─── Stat cards ─────────────────────────────────────── */
                    .cr-stat {
                        background: #fff;
                        border-radius: 16px;
                        border: 1px solid #F1F5F9;
                        box-shadow: 0 1px 4px rgba(15,23,42,.05);
                        padding: 1.35rem 1.5rem;
                        display: flex; align-items: center; gap: 1rem;
                        transition: transform .2s, box-shadow .2s;
                        height: 100%;
                    }
                    .cr-stat:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(15,23,42,.1); }
                    .cr-stat-ico {
                        width: 50px; height: 50px;
                        border-radius: 14px;
                        display: flex; align-items: center; justify-content: center;
                        font-size: 1.35rem; flex-shrink: 0;
                    }
                    .ico-indigo  { background: #EEF2FF; }
                    .ico-emerald { background: #ECFDF5; }
                    .ico-amber   { background: #FFFBEB; }
                    .ico-violet  { background: #F5F3FF; }
                    .cr-stat-val {
                        font-size: 1.7rem; font-weight: 800;
                        line-height: 1; letter-spacing: -.5px;
                        margin-bottom: .25rem;
                    }
                    .cr-stat-lbl {
                        font-size: .7rem; font-weight: 600;
                        text-transform: uppercase; letter-spacing: .8px;
                        color: #94A3B8;
                    }
                    .val-indigo  { color: #4F46E5; }
                    .val-emerald { color: #059669; }
                    .val-amber   { color: #D97706; }
                    .val-violet  { color: #7C3AED; }

                    /* ─── Card ───────────────────────────────────────────── */
                    .cr-card {
                        background: #fff;
                        border-radius: 16px;
                        border: 1px solid #F1F5F9;
                        box-shadow: 0 1px 4px rgba(15,23,42,.05);
                        overflow: hidden;
                        margin-bottom: 1.5rem;
                    }
                    .cr-card-head {
                        padding: 1.2rem 1.75rem;
                        border-bottom: 1px solid #F1F5F9;
                        display: flex; align-items: center; justify-content: space-between;
                    }
                    .cr-card-ttl {
                        font-size: .95rem; font-weight: 700; color: #0F172A;
                    }

                    /* ─── Table ──────────────────────────────────────────── */
                    .cr-tbl { width: 100%; border-collapse: collapse; }
                    .cr-tbl thead tr { background: #F8FAFC; }
                    .cr-tbl th {
                        padding: .8rem 1.5rem;
                        font-size: .68rem; font-weight: 700;
                        text-transform: uppercase; letter-spacing: .8px;
                        color: #94A3B8;
                        border-bottom: 1px solid #F1F5F9;
                        white-space: nowrap;
                    }
                    .cr-tbl td {
                        padding: .95rem 1.5rem;
                        font-size: .875rem; color: #334155;
                        border-bottom: 1px solid #F8FAFC;
                        vertical-align: middle;
                    }
                    .cr-tbl tbody tr:last-child td { border-bottom: none; }
                    .cr-tbl tbody tr { transition: background .12s; }
                    .cr-tbl tbody tr:hover td { background: #F8FAFC; }
                    .cr-tbl tfoot td {
                        padding: 1rem 1.5rem;
                        background: #F8FAFC;
                        border-top: 2px solid #E2E8F0;
                        font-size: .9rem; font-weight: 800;
                    }

                    /* ─── Avatar ─────────────────────────────────────────── */
                    .cr-av {
                        width: 38px; height: 38px; border-radius: 50%;
                        background: linear-gradient(135deg, #4F46E5, #7C3AED);
                        color: #fff; font-size: .78rem; font-weight: 700;
                        display: inline-flex; align-items: center; justify-content: center;
                        flex-shrink: 0; text-transform: uppercase; letter-spacing: .5px;
                    }
                    .cr-av-lg {
                        width: 54px; height: 54px; border-radius: 50%;
                        background: linear-gradient(135deg, #4F46E5, #7C3AED);
                        color: #fff; font-size: 1rem; font-weight: 800;
                        display: flex; align-items: center; justify-content: center;
                        flex-shrink: 0; text-transform: uppercase;
                    }

                    /* ─── Badges ─────────────────────────────────────────── */
                    .cr-pill {
                        display: inline-flex; align-items: center;
                        padding: .25rem .75rem;
                        border-radius: 50px; font-size: .75rem; font-weight: 600;
                    }
                    .pill-indigo  { background: #EEF2FF; color: #4F46E5; }
                    .pill-orange  { background: #FFF7ED; color: #C2410C; }
                    .pill-green   { background: #ECFDF5; color: #059669; }
                    .pill-slate   { background: #F1F5F9; color: #475569; }

                    /* ─── Action buttons ─────────────────────────────────── */
                    .cr-btn {
                        display: inline-flex; align-items: center; gap: .35rem;
                        border: none; border-radius: 8px;
                        font-size: .8rem; font-weight: 600;
                        padding: .38rem .85rem;
                        cursor: pointer; transition: all .15s;
                        text-decoration: none; white-space: nowrap;
                    }
                    .btn-view  { background: #EEF2FF; color: #4F46E5; }
                    .btn-view:hover  { background: #4F46E5; color: #fff; }
                    .btn-email { background: #ECFDF5; color: #059669; }
                    .btn-email:hover { background: #059669; color: #fff; }
                    .btn-primary-solid { background: #4F46E5; color: #fff; }
                    .btn-primary-solid:hover { background: #3730A3; color: #fff; }
                    .btn-ghost {
                        background: transparent; color: #475569;
                        border: 1.5px solid #E2E8F0;
                    }
                    .btn-ghost:hover { border-color: #4F46E5; color: #4F46E5; background: #EEF2FF; }

                    /* ─── AI insights card ───────────────────────────────── */
                    .cr-ai {
                        background: linear-gradient(135deg, #EEF2FF 0%, #F5F3FF 100%);
                        border: 1px solid #C7D2FE;
                        border-radius: 16px;
                        padding: 1.5rem 1.75rem;
                        margin-bottom: 1.5rem;
                    }
                    .cr-ai-hd {
                        display: flex; align-items: center; gap: .65rem;
                        margin-bottom: .9rem;
                    }
                    .cr-ai-ico {
                        width: 34px; height: 34px;
                        background: linear-gradient(135deg, #4F46E5, #7C3AED);
                        border-radius: 9px;
                        display: flex; align-items: center; justify-content: center;
                        font-size: .95rem; color: #fff; flex-shrink: 0;
                    }
                    .cr-ai-lbl {
                        font-size: .88rem; font-weight: 700; color: #3730A3;
                    }
                    .cr-ai-badge {
                        display: inline-block;
                        background: #4F46E5; color: #fff;
                        font-size: .6rem; font-weight: 700;
                        padding: 2px 7px; border-radius: 50px;
                        text-transform: uppercase; letter-spacing: .5px;
                        vertical-align: middle; margin-left: .4rem;
                    }
                    .cr-ai-body { font-size: .875rem; color: #374151; line-height: 1.8; }

                    /* ─── Rep profile bar (detail page) ──────────────────── */
                    .cr-profile {
                        background: #fff;
                        border-radius: 16px;
                        border: 1px solid #F1F5F9;
                        box-shadow: 0 1px 4px rgba(15,23,42,.05);
                        padding: 1.4rem 1.75rem;
                        display: flex; align-items: center;
                        justify-content: space-between;
                        flex-wrap: wrap; gap: 1rem;
                        margin-bottom: 1.5rem;
                    }

                    /* ─── Empty state ────────────────────────────────────── */
                    .cr-empty {
                        text-align: center;
                        padding: 4rem 2rem;
                        color: #94A3B8;
                    }
                    .cr-empty-ico { font-size: 2.75rem; margin-bottom: .75rem; }
                    .cr-empty-ttl { font-size: .95rem; font-weight: 600; color: #64748B; margin-bottom: .3rem; }
                    .cr-empty-sub { font-size: .82rem; }

                    /* ─── Toast ──────────────────────────────────────────── */
                    #cr-toasts {
                        position: fixed; bottom: 1.5rem; right: 1.5rem;
                        z-index: 9999;
                        display: flex; flex-direction: column; gap: .5rem;
                        pointer-events: none;
                    }
                    .cr-toast {
                        background: #0F172A; color: #fff;
                        padding: .85rem 1.2rem;
                        border-radius: 12px;
                        font-size: .84rem; font-weight: 500;
                        box-shadow: 0 8px 32px rgba(15,23,42,.28);
                        display: flex; align-items: center; gap: .6rem;
                        max-width: 320px;
                        animation: toastSlide .25s ease;
                        pointer-events: all;
                    }
                    .cr-toast.ok  { border-left: 4px solid #10B981; }
                    .cr-toast.err { border-left: 4px solid #EF4444; }
                    @keyframes toastSlide {
                        from { opacity: 0; transform: translateY(10px) scale(.97); }
                        to   { opacity: 1; transform: translateY(0)    scale(1);   }
                    }

                    /* ─── Divider ────────────────────────────────────────── */
                    .cr-divider {
                        height: 1px; background: #F1F5F9;
                        margin: 0;
                    }
                </style>
            </head>
            <body>

                <!-- ── Navbar ───────────────────────────────────────────── -->
                <nav class="cr-nav">
                    <a href="/sales/commission/report" class="cr-brand">
                        <div class="cr-brand-logo">📊</div>
                        Commission Reports
                    </a>
                    <div class="cr-nav-actions">
                        <a href="/sales/commission/report/my" class="cr-nbtn">My Report</a>
                        <a href="/web" class="cr-nbtn">← Back to Odoo</a>
                    </div>
                </nav>

                <!-- ── Toast container ──────────────────────────────────── -->
                <div id="cr-toasts"></div>

                <!-- ── Content ──────────────────────────────────────────── -->
                <div class="cr-page">
                    <t t-out="0"/>
                </div>

            </body>
        </html>
    </template>


    <!-- ═══════════════════════════════════════════════════════════════════
         INDEX PAGE — all reps dashboard
    ═══════════════════════════════════════════════════════════════════ -->
    <template id="report_commission_index" name="Commission Report — All Reps">
        <t t-call="sale_rep_commission_report.commission_layout">

        <!-- Hero -->
        <div class="cr-hero mb-4">
            <div class="cr-hero-inner d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="cr-hero-pill" t-out="month_label"/>
                    <h1 class="cr-hero-title">Sales Commission Dashboard</h1>
                    <p class="cr-hero-sub">Monthly performance overview for all sales representatives</p>
                </div>
                <div class="d-flex align-items-center gap-2" style="padding-top:.25rem;">
                    <button class="cr-hero-btn" onclick="sendAllEmails(this)">
                        ✉ Send All Emails
                    </button>
                </div>
            </div>
        </div>

        <!-- Stat cards -->
        <div class="row g-3 mb-4" t-if="summaries">
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-indigo">👥</div>
                    <div>
                        <div class="cr-stat-val val-indigo" t-out="len(summaries)"/>
                        <div class="cr-stat-lbl">Representatives</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-emerald">💰</div>
                    <div>
                        <div class="cr-stat-val val-emerald"
                             t-out="'{:,.0f}'.format(sum(s['total_sales'] for s in summaries))"/>
                        <div class="cr-stat-lbl">Total Revenue</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-amber">🏆</div>
                    <div>
                        <div class="cr-stat-val val-amber"
                             t-out="'{:,.0f}'.format(sum(s['commission_amount'] for s in summaries))"/>
                        <div class="cr-stat-lbl">Total Commissions</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-violet">📦</div>
                    <div>
                        <div class="cr-stat-val val-violet"
                             t-out="sum(s['order_count'] for s in summaries)"/>
                        <div class="cr-stat-lbl">Total Orders</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Representatives table -->
        <div class="cr-card">
            <div class="cr-card-head">
                <span class="cr-card-ttl">Representatives</span>
                <span class="cr-pill pill-slate" t-if="summaries"
                      t-out="str(len(summaries)) + ' reps'"/>
            </div>

            <!-- Empty -->
            <div class="cr-empty" t-if="not summaries">
                <div class="cr-empty-ico">📭</div>
                <p class="cr-empty-ttl">No commission configurations found</p>
                <p class="cr-empty-sub">
                    Go to <strong>Sales › Commission Config</strong> to add representatives.
                </p>
            </div>

            <!-- Table -->
            <div class="table-responsive" t-if="summaries">
                <table class="cr-tbl">
                    <thead>
                        <tr>
                            <th>Representative</th>
                            <th class="text-center">Orders</th>
                            <th class="text-end">Total Sales</th>
                            <th class="text-center">Rate</th>
                            <th class="text-end">Commission</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="summaries" t-as="s">
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="cr-av"
                                             t-out="s['user_name'][:2] if s['user_name'] else '?'"/>
                                        <div>
                                            <a t-attf-href="/sales/commission/report/#{s['config_id']}"
                                               class="fw-semibold text-decoration-none"
                                               style="color:#0F172A;font-size:.875rem;">
                                                <t t-out="s['user_name']"/>
                                            </a>
                                            <div style="font-size:.75rem;color:#94A3B8;margin-top:.1rem;"
                                                 t-out="s['email']"/>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="cr-pill pill-indigo" t-out="s['order_count']"/>
                                </td>
                                <td class="text-end fw-semibold" style="color:#0F172A;">
                                    <t t-out="s['currency_symbol']"/>
                                    <t t-out="'{:,.2f}'.format(s['total_sales'])"/>
                                </td>
                                <td class="text-center">
                                    <span class="cr-pill pill-orange">
                                        <t t-out="s['commission_rate']"/>%
                                    </span>
                                </td>
                                <td class="text-end fw-bold" style="color:#059669;font-size:.9rem;">
                                    <t t-out="s['currency_symbol']"/>
                                    <t t-out="'{:,.2f}'.format(s['commission_amount'])"/>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a t-attf-href="/sales/commission/report/#{s['config_id']}"
                                           class="cr-btn btn-view">View</a>
                                        <button class="cr-btn btn-email"
                                                t-att-data-config-id="s['config_id']"
                                                onclick="sendOneEmail(this)">
                                            Email
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>

        <script>
            function showToast(msg, ok) {
                const wrap = document.getElementById('cr-toasts');
                const el = document.createElement('div');
                el.className = 'cr-toast ' + (ok ? 'ok' : 'err');
                el.textContent = (ok ? '✅  ' : '❌  ') + msg;
                wrap.appendChild(el);
                setTimeout(() => el.remove(), 4500);
            }

            async function sendOneEmail(btn) {
                const id   = btn.dataset.configId;
                const orig = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Sending…';
                try {
                    const res  = await fetch('/sales/commission/send-email/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ jsonrpc: '2.0', method: 'call', params: {} }),
                    });
                    const data = await res.json();
                    const r    = data.result;
                    showToast(r.success ? r.message : r.error, r.success);
                } catch (e) {
                    showToast('Request failed: ' + e, false);
                } finally {
                    btn.disabled = false;
                    btn.textContent = orig;
                }
            }

            async function sendAllEmails(btn) {
                if (!confirm('Send commission emails to ALL active sales representatives?')) return;
                const orig = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Sending…';
                try {
                    const res  = await fetch('/sales/commission/send-all-emails', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ jsonrpc: '2.0', method: 'call', params: {} }),
                    });
                    const data = await res.json();
                    const r    = data.result;
                    showToast(r.success ? r.message : r.error, r.success);
                } catch (e) {
                    showToast('Request failed: ' + e, false);
                } finally {
                    btn.disabled = false;
                    btn.textContent = orig;
                }
            }
        </script>
        </t>
    </template>


    <!-- ═══════════════════════════════════════════════════════════════════
         DETAIL PAGE — single rep
    ═══════════════════════════════════════════════════════════════════ -->
    <template id="report_commission_detail" name="Commission Report — Detail">
        <t t-call="sale_rep_commission_report.commission_layout">

        <!-- Rep profile bar -->
        <div class="cr-profile">
            <div class="d-flex align-items-center gap-3">
                <div class="cr-av-lg" t-out="user_name[:2] if user_name else '?'"/>
                <div>
                    <div style="font-size:1.15rem;font-weight:800;color:#0F172A;line-height:1.2;"
                         t-out="user_name"/>
                    <div style="font-size:.8rem;color:#94A3B8;margin-top:.2rem;"
                         t-out="email"/>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="cr-pill pill-indigo" t-out="month_label"/>
                <t t-if="is_manager">
                    <a href="/sales/commission/report" class="cr-btn btn-ghost">← All Reps</a>
                    <button class="cr-btn btn-primary-solid"
                            t-att-data-config-id="config_id"
                            onclick="sendOneEmail(this)">
                        ✉ Send Email
                    </button>
                </t>
            </div>
        </div>

        <!-- Stat cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-indigo">📦</div>
                    <div>
                        <div class="cr-stat-val val-indigo" t-out="order_count"/>
