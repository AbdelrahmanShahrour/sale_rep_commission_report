                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-emerald">💰</div>
                    <div>
                        <div class="cr-stat-val val-emerald">
                            <t t-out="currency_symbol"/>
                            <t t-out="'{:,.0f}'.format(total_sales)"/>
                        </div>
                        <div class="cr-stat-lbl">Total Sales</div>
