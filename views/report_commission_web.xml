        </div>

        <!-- Orders table -->
        <div class="cr-card">
            <div class="cr-card-head">
                <span class="cr-card-ttl">Confirmed Orders — <t t-out="month_label"/></span>
                <span class="cr-pill pill-slate" t-if="orders"
                      t-out="str(len(orders)) + ' orders'"/>
            </div>

            <div class="cr-empty" t-if="not orders">
                <div class="cr-empty-ico">📭</div>
                <p class="cr-empty-ttl">No confirmed orders this month</p>
                <p class="cr-empty-sub">Orders in "Sale" or "Done" state appear here.</p>
            </div>

            <div class="table-responsive" t-if="orders">
                <table class="cr-tbl">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th class="text-end">Commission</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="orders" t-as="order">
                            <tr>
                                <td class="fw-semibold" style="color:#4F46E5;"
                                    t-out="order['name']"/>
                                <td t-out="order['partner']"/>
                                <td style="color:#94A3B8;" t-out="order['date']"/>
                                <td class="text-end fw-semibold" style="color:#0F172A;">
                                    <t t-out="currency_symbol"/>
                                    <t t-out="'{:,.2f}'.format(order['amount'])"/>
                                </td>
                                <td class="text-end fw-bold" style="color:#059669;">
                                    <t t-out="currency_symbol"/>
                                    <t t-out="'{:,.2f}'.format(order['amount'] * commission_rate / 100)"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" style="color:#64748B;">TOTAL</td>
                            <td class="text-end" style="color:#0F172A;">
                                <t t-out="currency_symbol"/>
                                <t t-out="'{:,.2f}'.format(total_sales)"/>
                            </td>
                            <td class="text-end" style="color:#059669;">
                                <t t-out="currency_symbol"/>
                                <t t-out="'{:,.2f}'.format(commission_amount)"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <script>
            function showToast(msg, ok) {
                const wrap = document.getElementById('cr-toasts');
                const el = document.createElement('div');
                el.className = 'cr-toast ' + (ok ? 'ok' : 'err');
                el.textContent = (ok ? '✅  ' : '❌  ') + msg;
                wrap.appendChild(el);
                setTimeout(() => el.remove(), 4500);
            }

            async function sendOneEmail(btn) {
                const id   = btn.dataset.configId;
                const orig = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Sending…';
                try {
                    const res  = await fetch('/sales/commission/send-email/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ jsonrpc: '2.0', method: 'call', params: {} }),
                    });
                    const data = await res.json();
                    const r    = data.result;
                    showToast(r.success ? r.message : r.error, r.success);
                } catch (e) {
                    showToast('Request failed: ' + e, false);
                } finally {
                    btn.disabled = false;
                    btn.textContent = orig;
                }
            }
        </script>
        </t>
    </template>


    <!-- ═══════════════════════════════════════════════════════════════════
         NO CONFIG PAGE
    ═══════════════════════════════════════════════════════════════════ -->
