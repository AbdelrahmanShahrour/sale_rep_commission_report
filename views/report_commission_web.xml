        <!-- AI Insights -->
        <div class="cr-ai" t-if="ai_insights">
            <div class="cr-ai-hd">
                <div class="cr-ai-ico">🤖</div>
                <div>
                    <span class="cr-ai-lbl">AI Performance Insights</span>
