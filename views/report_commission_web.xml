                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="cr-stat">
                    <div class="cr-stat-ico ico-violet">🏆</div>
                    <div>
                        <div class="cr-stat-val val-violet">
                            <t t-out="currency_symbol"/>
                            <t t-out="'{:,.2f}'.format(commission_amount)"/>
                        </div>
                        <div class="cr-stat-lbl">Commission Earned</div>
