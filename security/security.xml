<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Reps can read only their own commission config -->
        <record id="rule_commission_config_own_user" model="ir.rule">
            <field name="name">Commission Config: Own Record (User)</field>
            <field name="model_id" ref="model_sale_commission_config"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers see all commission configs in their company -->
        <record id="rule_commission_config_manager_company" model="ir.rule">
            <field name="name">Commission Config: Company Rule (Manager)</field>
            <field name="model_id" ref="model_sale_commission_config"/>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
